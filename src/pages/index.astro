---

import Layout from "../layouts/Layout.astro"

import CaseStudiesSection from "../components/CaseStudiesSection.astro"
import ClientsSection from "../components/ClientsSection.astro"
import FaqSection from "../components/FaqSection.astro"
import ServicesCarousel from "../components/ServicesCarousel.astro"
import HeroSection from "../components/HeroSection.astro"
import NewsletterSection from "../components/NewsletterSection.astro"
import PricingSection from "../components/PricingSection.astro"
import QuoteSection from "../components/QuoteSection.astro"
import TestimonialsSection from "../components/TestimonialsSection.astro"
import TeamPresentation from "../components/TeamPresentation.astro"
import ULogixPresentation from "../components/ULogixPresentation.astro"


import caseStudies from "../data/case_studies.json"
import clients from "../data/clients.json"
import faq from "../data/faq.json"
import services from "../data/services.json"
import home from "../data/home.json"
import pricing from "../data/pricing.json"
import global_settings from "../data/global_settings.json"
import newsletter from "../data/newsletter.json"
import testimonials from "../data/testimonials.json"
import people from "../data/people.json"
import WholeTeam from "../components/WholeTeam.astro"
---

<Layout title={ global_settings.title } variant ="home">

  <HeroSection
    content={ home.hero_content }
    settings={ global_settings }
    title={ home.hero_title }
  />

  <ServicesCarousel
    services={ services }
    title={ home.services_title }
  />

  <ClientsSection
    clients={ clients }
    title={ home.clients_title }
  />

  <QuoteSection
    cite={ home.quote_cite }
    content={ home.quote_content }
    image={ home.quote_image }
    role={ home.quote_role }
  />

    <WholeTeam 
    title="Nuestro Equipo Profesional"
    subtitle="Un grupo de expertos dedicados a ofrecer los mejores resultados"
    teamImage="/images/equipo-completo.jpg"
    imageAlt="Foto del equipo completo en nuestras oficinas"
    description="Contamos con un equipo multidisciplinario de profesionales altamente capacitados, comprometidos con la excelencia y la innovación."
  />
  
  <TeamPresentation 
    title = " Nuestro equipo" 
    people = { people }
  /> 

  <CaseStudiesSection
    caseStudies={ caseStudies }
    title={ home.case_studies_title }
  />

  <!-- <TestimonialsSection
    testimonials={ testimonials }
    title={ home.testimonials_title }
  /> -->

  <!-- <PricingSection
    pricing={ pricing }
    title={ home.pricing_title }
  /> -->



  <ULogixPresentation 
    title = "¿Por qué U-Logix?" 
    content = "En U-Logix, no solo ofrecemos soluciones de automatización, sino que también nos comprometemos a transformar la forma en que las plantas industriales operan. Nuestra propuesta de valor se basa en tres pilares fundamentales: innovación, personalización y resultados tangibles. Con un enfoque centrado en el cliente, trabajamos estrechamente con cada planta para entender sus desafíos únicos y diseñar soluciones a medida que optimicen sus procesos, reduzcan costos y aumenten la eficiencia. Nuestro equipo de expertos combina tecnología de vanguardia con un profundo conocimiento de la industria para garantizar que cada proyecto no solo cumpla, sino supere las expectativas. En U-Logix, estamos dedicados a impulsar la transformación digital en la industria, ayudando a las plantas a alcanzar su máximo potencial y mantenerse competitivas en un mercado en constante evolución."
  <FaqSection
    faq={ faq }
    title={ home.faq_title }
  />





  <NewsletterSection newsletter={newsletter} />

</Layout>
