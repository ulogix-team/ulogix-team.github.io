---
// DashboardMetricas.astro
// Componente dashboard industrial con métricas OEE, Takt Time, MLT y RP

export interface Props {
  oee?: {
    disponibilidad?: number;
    eficiencia?: number;
    calidad?: number;
    oeeTotal?: number;
  };
  taktTime?: {
    tiempoDisponible: number; // en segundos
    demandaCliente: number;   // unidades requeridas
    taktCalculado: number;    // en segundos
  };
  mlt?: {
    tiempoTotal: number;      // en horas o días
    unidad: 'horas' | 'dias';
  };
  rp?: {
    tiempoOperativo: number;  // horas de operación
    paradasNoProgramadas: number; // horas de parada
    rpCalculado: number;      // ratio de rendimiento
  };
}

// Valores por defecto para demostración
const {
  oee = {
    disponibilidad: 85.5,
    eficiencia: 92.3,
    calidad: 98.7,
    oeeTotal: 77.8
  },
  taktTime = {
    tiempoDisponible: 28800, // 8 horas en segundos
    demandaCliente: 500,
    taktCalculado: 57.6
  },
  mlt = {
    tiempoTotal: 48,
    unidad: 'horas'
  },
  rp = {
    tiempoOperativo: 720,    // 30 días * 24 horas
    paradasNoProgramadas: 45,
    rpCalculado: 93.75
  }
} = Astro.props;
---

<section class="dashboard-industrial container flex flex-col mx-auto px-5 py-10 rounded-lg">
  <div class="dashboard-header">
    <h2 class="dashboard-title">
      <i class="fa-solid fa-chart-line"></i>
      Dashboard de Métricas Industriales
    </h2>
    <p class="dashboard-subtitle">Indicadores clave de rendimiento en tiempo real</p>
  </div>

  <div class="dashboard-grid">
    
    <!-- Card OEE Principal -->
    <div class="metric-card card-oee">
      <div class="card-header">
        <i class="fa-solid fa-microchip"></i>
        <h3>OEE Global</h3>
        <span class="metric-badge">Overall Equipment Effectiveness</span>
      </div>
      
      <div class="oee-total">
        <div class="oee-circle" data-value={oee.oeeTotal}>
          <svg viewBox="0 0 120 120" class="progress-ring">
            <circle
              cx="60"
              cy="60"
              r="54"
              fill="none"
              stroke="rgba(255,255,255,0.1)"
              stroke-width="8"
            />
            <circle
              cx="60"
              cy="60"
              r="54"
              fill="none"
              stroke="url(#gradient-oee)"
              stroke-width="8"
              stroke-linecap="round"
              stroke-dasharray={`${2 * Math.PI * 54 * (oee.oeeTotal / 100)} ${2 * Math.PI * 54}`}
              transform="rotate(-90 60 60)"
              class="progress-ring-circle"
            />
            <defs>
              <linearGradient id="gradient-oee" x1="0%" y1="0%" x2="100%" y2="0%">
                <stop offset="0%" stop-color="#4CAF50" />
                <stop offset="100%" stop-color="#8BC34A" />
              </linearGradient>
            </defs>
          </svg>
          <div class="oee-value">
            <span class="big-number">{oee.oeeTotal.toFixed(1)}</span>
            <span class="unit">%</span>
          </div>
        </div>
        <div class="oee-status">
          <span class={`status-badge ${oee.oeeTotal >= 85 ? 'excellent' : oee.oeeTotal >= 60 ? 'good' : 'warning'}`}>
            {oee.oeeTotal >= 85 ? 'Excelente' : oee.oeeTotal >= 60 ? 'Bueno' : 'Requiere Mejora'}
          </span>
        </div>
      </div>

      <div class="oee-metrics">
        <div class="metric-item">
          <div class="metric-info">
            <i class="fa-solid fa-clock"></i>
            <span>Disponibilidad</span>
          </div>
          <div class="metric-value">
            <span class="value">{oee.disponibilidad.toFixed(1)}%</span>
            <div class="progress-bar">
              <div class="progress-fill" style={`width: ${oee.disponibilidad}%`}></div>
            </div>
          </div>
        </div>
        
        <div class="metric-item">
          <div class="metric-info">
            <i class="fa-solid fa-gauge-high"></i>
            <span>Eficiencia</span>
          </div>
          <div class="metric-value">
            <span class="value">{oee.eficiencia.toFixed(1)}%</span>
            <div class="progress-bar">
              <div class="progress-fill" style={`width: ${oee.eficiencia}%`}></div>
            </div>
          </div>
        </div>
        
        <div class="metric-item">
          <div class="metric-info">
            <i class="fa-solid fa-star"></i>
            <span>Calidad</span>
          </div>
          <div class="metric-value">
            <span class="value">{oee.calidad.toFixed(1)}%</span>
            <div class="progress-bar">
              <div class="progress-fill" style={`width: ${oee.calidad}%`}></div>
            </div>
          </div>
        </div>
      </div>
      
      <div class="card-footer">
        <i class="fa-regular fa-circle-info"></i>
        <span>OEE = Disponibilidad × Eficiencia × Calidad</span>
      </div>
    </div>

    <!-- Card Takt Time -->
    <div class="metric-card card-takt">
      <div class="card-header">
        <i class="fa-solid fa-hourglass-half"></i>
        <h3>Takt Time</h3>
        <span class="metric-badge">Ritmo de producción</span>
      </div>
      
      <div class="takt-display">
        <div class="takt-main">
          <span class="takt-value">{taktTime.taktCalculado.toFixed(4)}</span>
          <span class="takt-unit">segundos</span>
        </div>
        <div class="takt-formula">
          <div class="formula-item">
            <span class="label">Tiempo disponible:</span>
            <span class="value">{(taktTime.tiempoDisponible / 3600).toFixed(1)} hrs</span>
          </div>
          <div class="formula-item">
            <span class="label">Demanda cliente:</span>
            <span class="value">{taktTime.demandaCliente.toLocaleString()} uds</span>
          </div>
          <div class="formula-divider">
            <i class="fa-solid fa-equals"></i>
          </div>
          <div class="formula-result">
            <span class="result-label">Takt Time:</span>
            <span class="result-value">{taktTime.taktCalculado.toFixed(1)} seg/ud</span>
          </div>
        </div>
      </div>
      
      <div class="takt-info">
        <div class="info-item">
          <i class="fa-regular fa-clock"></i>
          <span>Debes producir 1 unidad cada {taktTime.taktCalculado.toFixed(1)} segundos para cumplir con la demanda</span>
        </div>
      </div>
    </div>

    <!-- Card MLT (Manufacturing Lead Time) -->
    <div class="metric-card card-mlt">
      <div class="card-header">
        <i class="fa-solid fa-timeline"></i>
        <h3>MLT</h3>
        <span class="metric-badge">Manufacturing Lead Time</span>
      </div>
      
      <div class="mlt-display">
        <div class="mlt-main">
          <span class="mlt-value">{mlt.tiempoTotal}</span>
          <span class="mlt-unit">{mlt.unidad === 'horas' ? 'horas' : 'días'}</span>
        </div>
        
        <div class="mlt-breakdown">
          <!-- <div class="breakdown-item">
            <i class="fa-solid fa-gear"></i>
            <span>Procesamiento</span>
            <strong>{Math.round(mlt.tiempoTotal * 0.35)} {mlt.unidad === 'horas' ? 'hrs' : 'días'}</strong>
          </div>
          <div class="breakdown-item">
            <i class="fa-solid fa-people-arrows"></i>
            <span>Espera/Movimiento</span>
            <strong>{Math.round(mlt.tiempoTotal * 0.45)} {mlt.unidad === 'horas' ? 'hrs' : 'días'}</strong>
          </div>
          <div class="breakdown-item">
            <i class="fa-solid fa-boxes"></i>
            <span>Inventario</span>
            <strong>{Math.round(mlt.tiempoTotal * 0.20)} {mlt.unidad === 'horas' ? 'hrs' : 'días'}</strong>
          </div> -->
        </div>
      </div>
      
      <div class="mlt-info">
        <div class="info-tip">
          <i class="fa-regular fa-lightbulb"></i>
          <span>Reducir MLT en un 30% puede aumentar la rentabilidad hasta un 15%</span>
        </div>
      </div>
    </div>

    <!-- Card RP (Rendimiento de Planta) -->
    <div class="metric-card card-rp">
      <div class="card-header">
        <i class="fa-solid fa-chart-simple"></i>
        <h3>RP - Rendimiento de Planta</h3>
        <span class="metric-badge">Rendimiento Productivo</span>
      </div>
      
      <div class="rp-display">
        <div class="rp-gauge">
          <div class="gauge-container">
            <div class="gauge-value" style={`--rp-value: ${rp.rpCalculado}`}>
              <span class="rp-value">{rp.rpCalculado.toFixed(1)}%</span>
            </div>
            <div class="gauge-bar">
              <div class="gauge-fill" style={`width: ${rp.rpCalculado}%`}></div>
            </div>
          </div>
        </div>
        
        <div class="rp-metrics">
          <div class="rp-metric">
            <i class="fa-solid fa-chart-line"></i>
            <div>
              <span class="label">Tiempo Operativo</span>
              <strong>{rp.tiempoOperativo.toFixed(0)} hrs</strong>
            </div>
          </div>
          <div class="rp-metric">
            <i class="fa-solid fa-triangle-exclamation"></i>
            <div>
              <span class="label">Paradas No Programadas</span>
              <strong>{rp.paradasNoProgramadas.toFixed(0)} hrs</strong>
            </div>
          </div>
          <!-- <div class="rp-metric highlight">
            <i class="fa-solid fa-percent"></i>
            <div>
              <span class="label">Rendimiento</span>
              <strong>{rp.rpCalculado.toFixed(1)}%</strong>
            </div>
          </div>
        </div> -->
      </div>
      
      <div class="rp-info">
        <div class="info-comparison">
          <span class="comparison-badge">
            <i class="fa-solid fa-arrow-up"></i>
            +5.2% vs mes anterior
          </span>
        </div>
      </div>
    </div>

  </div>
</section>

<style>
.dashboard-industrial {
  background: linear-gradient(135deg, #0a0c15 0%, #080b12 100%);
  border-radius: 1.5rem;
  padding: 2rem;
  font-family: 'Inter', system-ui, -apple-system, sans-serif;
  position: relative;
  overflow: hidden;
}

.dashboard-industrial::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4px;
  background: linear-gradient(90deg, #4CAF50, #2196F3, #FF9800);
}

.dashboard-header {
  text-align: center;
  margin-bottom: 2.5rem;
  position: relative;
  z-index: 1;
}

.dashboard-title {
  font-size: 1.8rem;
  font-weight: 700;
  background: linear-gradient(135deg, #fff, #a0a0a0);
  background-clip: text;
  -webkit-background-clip: text;
  color: transparent;
  margin-bottom: 0.5rem;
  display: inline-flex;
  align-items: center;
  gap: 0.8rem;
}

.dashboard-title i {
  background: linear-gradient(135deg, #4CAF50, #2196F3);
  background-clip: text;
  -webkit-background-clip: text;
  color: transparent;
  font-size: 1.6rem;
}

.dashboard-subtitle {
  color: #8a8a9a;
  font-size: 0.9rem;
}

.dashboard-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1.5rem;
  position: relative;
  z-index: 1;
}

.metric-card {
  background: rgba(15, 20, 30, 0.6);
  backdrop-filter: blur(10px);
  border-radius: 1.2rem;
  padding: 1.5rem;
  border: 1px solid rgba(100, 100, 150, 0.2);
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.metric-card:hover {
  transform: translateY(-4px);
  border-color: rgba(76, 175, 80, 0.3);
  box-shadow: 0 8px 25px rgba(0, 0, 0, 0.3);
}

.card-header {
  display: flex;
  align-items: center;
  gap: 0.8rem;
  margin-bottom: 1.5rem;
  flex-wrap: wrap;
}

.card-header i {
  font-size: 1.5rem;
  color: #4CAF50;
}

.card-header h3 {
  font-size: 1.2rem;
  font-weight: 600;
  color: #fff;
  margin: 0;
}

.metric-badge {
  font-size: 0.7rem;
  background: rgba(76, 175, 80, 0.2);
  color: #8BC34A;
  padding: 0.2rem 0.6rem;
  border-radius: 20px;
  margin-left: auto;
}

/* OEE Card Styles */
.card-oee {
  grid-column: span 1;
}

.oee-total {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 1.5rem;
}

.oee-circle {
  position: relative;
  width: 140px;
  height: 140px;
  margin-bottom: 1rem;
}

.progress-ring {
  width: 100%;
  height: 100%;
}

.progress-ring-circle {
  transition: stroke-dasharray 0.5s ease;
}

.oee-value {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  text-align: center;
}

.big-number {
  font-size: 2rem;
  font-weight: 800;
  color: #fff;
}

.unit {
  font-size: 0.9rem;
  color: #8a8a9a;
  margin-left: 2px;
}

.status-badge {
  padding: 0.3rem 1rem;
  border-radius: 20px;
  font-size: 0.75rem;
  font-weight: 500;
}

.status-badge.excellent {
  background: rgba(76, 175, 80, 0.2);
  color: #4CAF50;
}

.status-badge.good {
  background: rgba(33, 150, 243, 0.2);
  color: #2196F3;
}

.status-badge.warning {
  background: rgba(255, 152, 0, 0.2);
  color: #FF9800;
}

.oee-metrics {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.metric-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: 0.5rem;
}

.metric-info {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  color: #b0b0c0;
  font-size: 0.85rem;
}

.metric-info i {
  font-size: 0.9rem;
  color: #4CAF50;
}

.metric-value {
  flex: 1;
  min-width: 150px;
}

.value {
  display: inline-block;
  margin-bottom: 0.3rem;
  font-weight: 600;
  color: #fff;
}

.progress-bar {
  background: rgba(255, 255, 255, 0.1);
  height: 6px;
  border-radius: 3px;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #4CAF50, #8BC34A);
  border-radius: 3px;
  transition: width 0.5s ease;
}

.card-footer {
  margin-top: 1rem;
  padding-top: 1rem;
  border-top: 1px solid rgba(100, 100, 150, 0.2);
  font-size: 0.7rem;
  color: #8a8a9a;
  display: flex;
  align-items: center;
  gap: 0.5rem;
}

/* Takt Time Card */
.takt-display {
  text-align: center;
}

.takt-main {
  margin-bottom: 1.5rem;
}

.takt-value {
  font-size: 3rem;
  font-weight: 800;
  background: linear-gradient(135deg, #2196F3, #64B5F6);
  background-clip: text;
  -webkit-background-clip: text;
  color: transparent;
}

.takt-unit {
  font-size: 0.9rem;
  color: #8a8a9a;
  margin-left: 0.5rem;
}

.takt-formula {
  background: rgba(0, 0, 0, 0.3);
  border-radius: 1rem;
  padding: 1rem;
  margin: 1rem 0;
}

.formula-item {
  display: flex;
  justify-content: space-between;
  padding: 0.4rem 0;
  font-size: 0.85rem;
}

.formula-item .label {
  color: #8a8a9a;
}

.formula-item .value {
  color: #fff;
  font-weight: 500;
}

.formula-divider {
  text-align: center;
  padding: 0.5rem 0;
  color: #4CAF50;
}

.formula-result {
  display: flex;
  justify-content: space-between;
  padding-top: 0.5rem;
  margin-top: 0.5rem;
  border-top: 1px solid rgba(100, 100, 150, 0.2);
  font-weight: 600;
}

.result-label {
  color: #8a8a9a;
}

.result-value {
  color: #4CAF50;
}

.takt-info {
  background: rgba(33, 150, 243, 0.1);
  border-radius: 0.8rem;
  padding: 0.8rem;
  margin-top: 1rem;
}

.info-item {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  font-size: 0.8rem;
  color: #b0b0c0;
}

.info-item i {
  color: #2196F3;
}

/* MLT Card */
.mlt-main {
  text-align: center;
  margin-bottom: 1.5rem;
  padding: 1rem;
  background: linear-gradient(135deg, rgba(255, 152, 0, 0.1), rgba(255, 152, 0, 0.05));
  border-radius: 1rem;
}

.mlt-value {
  font-size: 3rem;
  font-weight: 800;
  background: linear-gradient(135deg, #FF9800, #FFB74D);
  background-clip: text;
  -webkit-background-clip: text;
  color: transparent;
}

.mlt-unit {
  font-size: 0.9rem;
  color: #8a8a9a;
  margin-left: 0.5rem;
}

.mlt-breakdown {
  display: flex;
  flex-direction: column;
  gap: 0.8rem;
  margin: 1rem 0;
}

.breakdown-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0.5rem;
  background: rgba(0, 0, 0, 0.2);
  border-radius: 0.6rem;
  font-size: 0.85rem;
}

.breakdown-item i {
  color: #FF9800;
  width: 24px;
}

.breakdown-item strong {
  color: #FFB74D;
}

.mlt-info {
  margin-top: 1rem;
}

.info-tip {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  font-size: 0.75rem;
  color: #FFB74D;
  background: rgba(255, 152, 0, 0.1);
  padding: 0.6rem;
  border-radius: 0.6rem;
}

/* RP Card */
.rp-display {
  margin: 1rem 0;
}

.rp-gauge {
  margin-bottom: 1.5rem;
}

.gauge-container {
  text-align: center;
}

.gauge-value {
  margin-bottom: 0.8rem;
}

.rp-value {
  font-size: 2.5rem;
  font-weight: 800;
  background: linear-gradient(135deg, #9C27B0, #BA68C8);
  background-clip: text;
  -webkit-background-clip: text;
  color: transparent;
}

.gauge-bar {
  background: rgba(255, 255, 255, 0.1);
  height: 10px;
  border-radius: 5px;
  overflow: hidden;
}

.gauge-fill {
  height: 100%;
  background: linear-gradient(90deg, #9C27B0, #BA68C8);
  border-radius: 5px;
  transition: width 0.5s ease;
}

.rp-metrics {
  display: flex;
  flex-direction: column;
  gap: 0.8rem;
  margin: 1rem 0;
}

.rp-metric {
  display: flex;
  align-items: center;
  gap: 0.8rem;
  padding: 0.6rem;
  background: rgba(0, 0, 0, 0.2);
  border-radius: 0.6rem;
}

.rp-metric i {
  font-size: 1rem;
  width: 24px;
  color: #9C27B0;
}

.rp-metric div {
  flex: 1;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.rp-metric .label {
  font-size: 0.8rem;
  color: #8a8a9a;
}

.rp-metric strong {
  color: #fff;
  font-size: 0.9rem;
}

.rp-metric.highlight {
  background: rgba(156, 39, 176, 0.2);
  border: 1px solid rgba(156, 39, 176, 0.3);
}

.rp-metric.highlight strong {
  color: #BA68C8;
  font-size: 1rem;
}

.rp-info {
  margin-top: 1rem;
  text-align: center;
}

.comparison-badge {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.4rem 1rem;
  background: rgba(76, 175, 80, 0.2);
  color: #4CAF50;
  border-radius: 20px;
  font-size: 0.75rem;
  font-weight: 500;
}

/* Responsive */
@media (max-width: 1024px) {
  .dashboard-grid {
    grid-template-columns: 1fr;
  }
  
  .card-oee {
    grid-column: span 1;
  }
}

@media (max-width: 768px) {
  .dashboard-industrial {
    padding: 1rem;
  }
  
  .dashboard-title {
    font-size: 1.4rem;
  }
  
  .metric-card {
    padding: 1rem;
  }
  
  .takt-value,
  .mlt-value,
  .rp-value {
    font-size: 2rem;
  }
}
</style>