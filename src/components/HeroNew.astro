---
const { title, subtitle } = Astro.props
---

<section class="relative flex items-center justify-center overflow-hidden" style="min-height: calc(100vh - 80px); margin-top: 0px;">
  {/* Decoradores sutiles con textura transparente */}
  <div class="absolute inset-0 pointer-events-none">
    {/* Cuadrícula transparente muy sutil */}
    <div class="absolute inset-0 bg-[linear-gradient(to_right,#ffffff08_1px,transparent_1px),linear-gradient(to_bottom,#ffffff08_1px,transparent_1px)] bg-[size:4rem_4rem]"></div>
    
    {/* Gradientes radiales suaves para dar profundidad */}
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-gradient-to-r from-emerald-500/5 via-cyan-500/5 to-transparent rounded-full blur-3xl animate-pulse-slow"></div>
    <div class="absolute bottom-0 right-0 w-[500px] h-[500px] bg-gradient-to-l from-purple-500/5 to-transparent rounded-full blur-3xl animate-pulse-slow animation-delay-2000"></div>
    
    {/* Puntos decorativos animados */}
    <div class="absolute top-1/4 right-1/4 w-1 h-1 bg-white/20 rounded-full animate-float"></div>
    <div class="absolute bottom-1/3 left-1/3 w-1.5 h-1.5 bg-emerald-400/20 rounded-full animate-float animation-delay-1000"></div>
    <div class="absolute top-2/3 right-1/3 w-1 h-1 bg-cyan-400/20 rounded-full animate-float animation-delay-2000"></div>
    <div class="absolute bottom-1/4 right-1/3 w-1 h-1 bg-white/20 rounded-full animate-float animation-delay-3000"></div>
  </div>

  <div class="container mx-auto px-5 max-w-5xl relative z-10 text-center mb-20">
    {/* Badge profesional con // */}
    <div class="inline-flex items-center gap-3 text-white/50 text-sm font-mono tracking-wider mb-6 animate-fade-in">
      <span>INNOVACIÓN</span>
      <span className="text-white/30">//</span>
      <span>ESTRATEGIA</span>
    </div>

    {/* Título principal */}
    <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold text-white mb-6 tracking-tight animate-fade-in">
      {title}
    </h1>

    {/* Subtítulo */}
    <p class="text-white/60 text-lg md:text-xl lg:text-2xl max-w-3xl mx-auto leading-relaxed animate-fade-in-delay">
      {subtitle}
    </p>
  </div>

  {/* Animación de swipe down - solo flecha centrada */}
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-swipe-down">
    <svg class="w-8 h-8 text-white/40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7-7-7m14-6l-7 7-7-7"></path>
    </svg>
  </div>
</section>

<style is:global>
  /* Animación de fade in para el título */
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  
  .animate-fade-in {
    animation: fadeIn 0.8s ease-out forwards;
  }
  
  .animate-fade-in-delay {
    animation: fadeIn 0.8s ease-out 0.3s forwards;
    opacity: 0;
    animation-fill-mode: forwards;
  }
  
  /* Animación de pulse lento para los gradientes */
  @keyframes pulseSlow {
    0%, 100% {
      opacity: 0.3;
      transform: translate(-50%, -50%) scale(1);
    }
    50% {
      opacity: 0.6;
      transform: translate(-50%, -50%) scale(1.05);
    }
  }
  
  .animate-pulse-slow {
    animation: pulseSlow 4s ease-in-out infinite;
  }
  
  /* Animación de float para los puntos */
  @keyframes float {
    0%, 100% {
      transform: translateY(0px) translateX(0px);
      opacity: 0.2;
    }
    50% {
      transform: translateY(-10px) translateX(5px);
      opacity: 0.5;
    }
  }
  
  .animate-float {
    animation: float 6s ease-in-out infinite;
  }
  
  /* Animación de swipe down - solo flecha */
  @keyframes swipeDown {
    0%, 100% {
      transform: translateX(-50%) translateY(0);
      opacity: 0.5;
    }
    50% {
      transform: translateX(-50%) translateY(12px);
      opacity: 1;
    }
  }
  
  .animate-swipe-down {
    animation: swipeDown 2s ease-in-out infinite;
  }
  
  /* Delay utilities */
  .animation-delay-1000 {
    animation-delay: 1s;
  }
  
  .animation-delay-2000 {
    animation-delay: 2s;
  }
  
  .animation-delay-3000 {
    animation-delay: 3s;
  }
</style>