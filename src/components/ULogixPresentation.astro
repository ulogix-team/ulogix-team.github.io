---
// AboutSection.astro
// Full viewport height "About Us" section with rich textures,
// central isologo with subtle gradient rings, and professional startup aesthetic.

const {
  missionTitle = "Misión",
  visionTitle = "Visión",
  missionText = "Democratizar la innovación tecnológica mediante soluciones escalables que empoderen a empresas y personas para alcanzar su máximo potencial en la era digital.",
  visionText = "Construir el ecosistema tecnológico más influyente de Latinoamérica, donde la inteligencia artificial y el diseño humano converjan para crear experiencias extraordinarias.",
  isologoSrc = "/logo.svg",
  isologoAlt = "Company Isologo"
} = Astro.props;


import logo from "../assets/logo.png";
---

<section class="about-startup mt-50 pt-20" id="about-us">
  <div class="noise-overlay"></div>
  <div class="gradient-orb orb-1"></div>
  <div class="gradient-orb orb-2"></div>
  
  <div class="container">
    <!-- Header -->
    <div class="header">
      <span class="badge">Conócenos</span>
      <h1 class="title">Quiénes <span class="title-accent">Somos</span></h1>
      <h4>Somos ULogix. Una Empresa que busca cambiar la automatización industrial y la digitalización de los procesos.</h4>
      <div class="title-line"></div>
    </div>

    <!-- Content -->
    <div class="content-grid">
      <!-- Mission -->
      <div class="text-block">
        <div class="block-marker">01</div>
        <h2 class="block-title">{missionTitle}</h2>
        <p class="block-text">{missionText}</p>
        <div class="block-decoration"></div>
      </div>

      <!-- Logo Center -->
      <div class="logo-arena">
        <div class="rings">
          <div class="ring ring-1"></div>
          <div class="ring ring-2"></div>
          <div class="ring ring-3"></div>
        </div>
        <div class="logo-core">
          <img src={logo["src"]} alt={isologoAlt} class="isologo" />
        </div>
      </div>

      <!-- Vision -->
      <div class="text-block">
        <div class="block-marker">02</div>
        <h2 class="block-title">{visionTitle}</h2>
        <p class="block-text">{visionText}</p>
        <div class="block-decoration"></div>
      </div>
    </div>

    <!-- Scroll hint -->
    <div class="scroll-hint">
      <span></span>
    </div>
  </div>
</section>

<style>
  /* Full viewport height section */
  .about-startup {
    position: relative;
    min-height: 100vh;
    height: 100vh;
    display: flex;
    align-items: center;
    background: #03030a;
    overflow: hidden;
  }

  /* Rich texture overlays */
  .noise-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.08'/%3E%3C/svg%3E");
    background-repeat: repeat;
    background-size: 120px;
    pointer-events: none;
    z-index: 1;
  }

  /* Gradient orbs for depth */
  .gradient-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(100px);
    opacity: 0.3;
    z-index: 0;
  }

  .orb-1 {
    width: 60vh;
    height: 60vh;
    background: radial-gradient(circle, rgba(99, 102, 241, 0.5), rgba(139, 92, 246, 0.2));
    top: -20vh;
    right: -10vh;
    animation: float 20s ease-in-out infinite;
  }

  .orb-2 {
    width: 50vh;
    height: 50vh;
    background: radial-gradient(circle, rgba(236, 72, 153, 0.4), rgba(99, 102, 241, 0.1));
    bottom: -15vh;
    left: -10vh;
    animation: float 25s ease-in-out infinite reverse;
  }

  @keyframes float {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(5%, 5%) scale(1.05); }
  }

  .container {
    position: relative;
    max-width: 1400px;
    width: 90%;
    margin: 0 auto;
    padding: 2rem;
    z-index: 2;
    display: flex;
    flex-direction: column;
    justify-content: center;
    height: 100%;
  }

  /* Elegant header */
  .header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .badge {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    color: #a78bfa;
    background: rgba(99, 102, 241, 0.1);
    padding: 0.5rem 1.25rem;
    border-radius: 2rem;
    border: 1px solid rgba(99, 102, 241, 0.2);
    backdrop-filter: blur(4px);
    margin-bottom: 1.5rem;
  }

  .title {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 700;
    margin: 0;
    color: #ffffff;
    letter-spacing: -0.02em;
  }

  .title-accent {
    background: linear-gradient(135deg, #a78bfa, #6366f1, #ec489a);
    background-clip: text;
    -webkit-background-clip: text;
    color: transparent;
    position: relative;
  }

  .title-line {
    width: 80px;
    height: 2px;
    background: linear-gradient(90deg, #6366f1, #a855f7, transparent);
    margin: 1.5rem auto 0;
  }

  /* Main grid - balanced layout */
  .content-grid {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 3rem;
    flex: 1;
  }

  /* Text blocks - professional minimalism */
  .text-block {
    position: relative;
    padding: 1rem;
  }

  .block-marker {
    font-size: 0.875rem;
    font-weight: 500;
    color: #6366f1;
    letter-spacing: 0.1em;
    margin-bottom: 1rem;
    opacity: 0.7;
  }

  .block-title {
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 600;
    margin: 0 0 1.25rem 0;
    background: linear-gradient(135deg, #f0f9ff, #c4b5fd);
    background-clip: text;
    -webkit-background-clip: text;
    color: transparent;
  }

  .block-text {
    font-size: clamp(0.875rem, 1.8vw, 1rem);
    line-height: 1.7;
    color: #94a3b8;
    margin: 0;
  }

  .block-decoration {
    width: 40px;
    height: 1px;
    background: linear-gradient(90deg, #6366f1, transparent);
    margin-top: 1.5rem;
  }

  /* Right block decoration mirrored */
  .text-block:last-child .block-decoration {
    background: linear-gradient(270deg, #6366f1, transparent);
    margin-left: auto;
  }

  /* Center logo arena */
  .logo-arena {
    position: relative;
    width: 280px;
    height: 280px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .rings {
    position: absolute;
    width: 100%;
    height: 100%;
  }

  .ring {
    position: absolute;
    border-radius: 50%;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    border: 1px solid rgba(99, 102, 241, 0.3);
  }

  .ring-1 {
    width: 100%;
    height: 100%;
    animation: rotateRing 20s linear infinite;
    border-color: rgba(99, 102, 241, 0.4);
  }

  .ring-2 {
    width: 80%;
    height: 80%;
    animation: rotateRingReverse 15s linear infinite;
    border-color: rgba(168, 85, 247, 0.3);
  }

  .ring-3 {
    width: 60%;
    height: 60%;
    animation: rotateRing 10s linear infinite;
    border-color: rgba(236, 72, 153, 0.25);
    box-shadow: 0 0 20px rgba(99, 102, 241, 0.2);
  }

  @keyframes rotateRing {
    from { transform: translate(-50%, -50%) rotate(0deg); }
    to { transform: translate(-50%, -50%) rotate(360deg); }
  }

  @keyframes rotateRingReverse {
    from { transform: translate(-50%, -50%) rotate(360deg); }
    to { transform: translate(-50%, -50%) rotate(0deg); }
  }

  .logo-core {
    width: 130px;
    height: 130px;
    background: rgba(8, 8, 20, 0.8);
    backdrop-filter: blur(12px);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 10;
    border: 1px solid rgba(99, 102, 241, 0.3);
    transition: all 0.4s cubic-bezier(0.2, 0.9, 0.4, 1.1);
    box-shadow: 0 0 40px rgba(99, 102, 241, 0.1);
  }

  .logo-core:hover {
    transform: scale(1.02);
    border-color: rgba(99, 102, 241, 0.6);
    box-shadow: 0 0 60px rgba(99, 102, 241, 0.2);
  }

  .isologo {
    max-width: 65%;
    max-height: 65%;
    object-fit: contain;
    filter: drop-shadow(0 0 12px rgba(99, 102, 241, 0.3));
  }

  /* Scroll hint */
  .scroll-hint {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    opacity: 0.5;
    transition: opacity 0.3s ease;
  }

  .scroll-hint span {
    width: 24px;
    height: 40px;
    border: 1.5px solid rgba(148, 163, 184, 0.5);
    border-radius: 20px;
    position: relative;
  }

  .scroll-hint span::before {
    content: "";
    position: absolute;
    top: 8px;
    left: 50%;
    transform: translateX(-50%);
    width: 3px;
    height: 8px;
    background: #94a3b8;
    border-radius: 2px;
    animation: scrollHint 2s ease-in-out infinite;
  }

  @keyframes scrollHint {
    0% { opacity: 1; transform: translateX(-50%) translateY(0); }
    80% { opacity: 0; transform: translateX(-50%) translateY(12px); }
    100% { opacity: 0; transform: translateX(-50%) translateY(0); }
  }

  /* Responsive */
  @media (max-width: 900px) {
    .about-startup {
      height: auto;
      min-height: 100vh;
      padding: 4rem 0;
    }

    .container {
      justify-content: center;
    }

    .content-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .logo-arena {
      order: -1;
      margin: 1rem auto;
    }

    .text-block {
      text-align: center;
      max-width: 500px;
      margin: 0 auto;
    }

    .block-decoration {
      margin: 1.5rem auto 0 !important;
      background: linear-gradient(90deg, #6366f1, #a855f7, transparent) !important;
    }

    .scroll-hint {
      display: none;
    }

    .orb-1, .orb-2 {
      opacity: 0.2;
    }
  }

  @media (max-width: 480px) {
    .container {
      width: 95%;
      padding: 1rem;
    }

    .badge {
      font-size: 0.7rem;
      letter-spacing: 0.2em;
    }

    .logo-arena {
      width: 220px;
      height: 220px;
    }

    .logo-core {
      width: 100px;
      height: 100px;
    }

    .block-title {
      font-size: 1.5rem;
    }
  }
</style>    