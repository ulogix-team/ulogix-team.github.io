---

import CardCaseStudy from './CardCaseStudy.astro'

const { title, caseStudies } = Astro.props

---

<section class="bs-container bs-mt-lg" id="case-studies">

  <!-- Header -->
  { title && <h2 class="bs-h2 text-center md:text-left">{ title }</h2> }

  <div class="bs-h8 mt-5 mb-4">
  En la nuestra propuesta de automatización, nos centraremos en tres tipos de productos
  </div>
  <!-- Case Study 1 -->
  <!-- <div class="bs-mt-md">



  </div> -->

  <!-- Case studies -->
  <div class="mt-3 grid lg:grid-cols-3 gap-8">
    <CardCaseStudy caseStudy={ caseStudies[0] } />
    <CardCaseStudy caseStudy={ caseStudies[1] } />
    <CardCaseStudy caseStudy={ caseStudies[2] } />

  </div>

</section>

